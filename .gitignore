```gitignore
# ==========================================================
# Python Cache
# ==========================================================

__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# Virtual Environment
# ==========================================================

venv/
.venv/
env/
ENV/

# ==========================================================
# VS Code / JetBrains
# ==========================================================

.vscode/
.idea/

# ==========================================================
# Environment Variables
# ==========================================================

.env
.env.*

# ==========================================================
# Jupyter
# ==========================================================

.ipynb_checkpoints/

# ==========================================================
# Build / Distribution
# ==========================================================

build/
dist/
*.egg-info/

# ==========================================================
# Logs
# ==========================================================

*.log

# ==========================================================
# Testing
# ==========================================================

.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ==========================================================
# Generated Results
# ==========================================================

# results/csv/
# results/plots/
# results/reports/


# ==========================================================
# Operating System Files
# ==========================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Temporary Files
# ==========================================================

*.tmp
*.bak
*.cache
```
